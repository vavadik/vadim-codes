{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [".env"],
  "globalEnv": ["DATABASE_URL", "JWT_SECRET"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "//#quality": {
      "dependsOn": ["//#lint", "//#format"]
    },
    "//#quality:fix": {
      "dependsOn": ["//#lint:fix", "//#format:fix"]
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#format": {},
    "//#format:fix": {
      "dependsOn": ["//#lint:fix"],
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "clip-service#install:py": {
      "inputs": ["pyproject.toml", "uv.lock"],
      "outputs": [".venv/**"]
    },
    "composer-ai-api#dev": {
      "dependsOn": [
        "@vadim-codes/composer-ai-contracts#build",
        "@vadim-codes/composer-ai-db#build",
        "clip-service#install:py"
      ],
      "env": [
        "COMPOSER_AI_API_PORT",
        "COMPOSER_AI_DB_NAME",
        "SF_CLIENT_ID",
        "SF_CLIENT_SECRET",
        "SF_INSTANCE_URL",
        "SF_CALLBACK_URL",
        "SF_AUTH_SUCCESS_REDIRECT",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GITHUB_CALLBACK_URL",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_CALLBACK_URL",
        "CLIP_WORKER_PATH"
      ],
      "cache": false,
      "persistent": true
    },
    "composer-ai-web#dev": {
      "dependsOn": ["@vadim-codes/composer-ai-contracts#build"],
      "env": ["COMPOSER_AI_API_PORT"],
      "cache": false,
      "persistent": true
    },
    "poker-api#dev": {
      "dependsOn": ["@vadim-codes/poker-contracts#build", "@vadim-codes/poker-db#build"],
      "env": ["POKER_API_PORT", "POKER_DB_NAME"],
      "cache": false,
      "persistent": true
    },
    "poker-web#dev": {
      "dependsOn": ["@vadim-codes/poker-contracts#build"],
      "env": ["POKER_API_PORT"],
      "cache": false,
      "persistent": true
    },
    "boilerplate-api#dev": {
      "dependsOn": [
        "@vadim-codes/boilerplate-contracts#build",
        "@vadim-codes/boilerplate-db#build"
      ],
      "cache": false,
      "persistent": true
    },
    "boilerplate-web#dev": {
      "dependsOn": ["@vadim-codes/boilerplate-contracts#build"],
      "cache": false,
      "persistent": true
    },
    "sandbox-api#dev": {
      "dependsOn": ["@vadim-codes/sandbox-contracts#build", "@vadim-codes/sandbox-db#build"],
      "env": [
        "SANDBOX_API_PORT",
        "SANDBOX_DB_NAME",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GITHUB_CALLBACK_URL",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_CALLBACK_URL"
      ],
      "cache": false,
      "persistent": true
    },
    "sandbox-web#dev": {
      "dependsOn": ["@vadim-codes/sandbox-contracts#build"],
      "env": ["SANDBOX_API_PORT"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false
    },
    "migrate": {
      "dependsOn": ["^migrate"],
      "cache": false
    }
  }
}
