# PostgreSQL (docker-compose)
POSTGRES_USER=composer
POSTGRES_PASSWORD=composer
POSTGRES_DB=composer_ai
POSTGRES_PORT=5432
ADMINER_PORT=8080

# Base DB connection — no database name
DATABASE_URL="postgresql://composer:composer@localhost:5432"
COMPOSER_AI_API_PORT=3000
POKER_API_PORT=3001
SANDBOX_API_PORT=3002

# Per-app database names
COMPOSER_AI_DB_NAME=composer_ai
POKER_DB_NAME=poker
SANDBOX_DB_NAME=sandbox

# Salesforce OAuth
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_INSTANCE_URL=https://login.salesforce.com
SF_CALLBACK_URL=http://localhost:5173/api/auth/salesforce/callback
SF_AUTH_SUCCESS_REDIRECT=http://localhost:5173

# JWT
JWT_SECRET=

#GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5173/api/auth/github/callback

#Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
