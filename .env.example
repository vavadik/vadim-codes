# PostgreSQL (docker-compose)
POSTGRES_USER=composer
POSTGRES_PASSWORD=composer
POSTGRES_DB=composer_ai
POSTGRES_PORT=5432
ADMINER_PORT=8080

# API
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}"
PORT=3000

# Salesforce OAuth
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret
SF_INSTANCE_URL=https://login.salesforce.com
SF_CALLBACK_URL=http://localhost:5173/api/auth/salesforce/callback
SF_AUTH_SUCCESS_REDIRECT=http://localhost:5173

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=
